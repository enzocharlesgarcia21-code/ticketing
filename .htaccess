# Block .env files
<FilesMatch "^\.env">
    Require all denied
</FilesMatch>

# Block env.php and other config files
<FilesMatch "(env\.php|config\.php)">
    Require all denied
</FilesMatch>

# Block composer files
<FilesMatch "(composer\.json|composer\.lock)">
    Require all denied
</FilesMatch>

# Block .git folder
RedirectMatch 403 /\.git

# Disable directory listing
Options -Indexes